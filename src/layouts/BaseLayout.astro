---
import "../styles/base.css";
import "../styles/site.css";
import SiteFooter from "../components/SiteFooter.astro";

const {
	title = "Bella Technologies | Professional Digital Studio",
	description = "Bella Technologies delivers clean, scalable digital experiences for modern brands.",
} = Astro.props;

const companyName = "Bella Technologies";
const pathname = Astro.url.pathname;
const isContactPage = pathname === "/contact/";
const navItems = [
	{ label: "Home", href: "/" },
	{ label: "About", href: "/about/" },
	{ label: "Portfolio", href: "/portfolio/" },
	{ label: "Blog", href: "/blog/" },
	{ label: "Contact", href: "/contact/" },
];

const isActive = (href: string) =>
	pathname === href || (href !== "/" && pathname.startsWith(href));

const isTruthyFlag = (value: unknown) => {
	if (value == null) return false;
	return ["true", "1", "yes", "on"].includes(String(value).toLowerCase());
};

const googleAnalyticsEnabled = isTruthyFlag(
	import.meta.env.GOOGLE_ANALYTICS_ENABLED ?? process.env.GOOGLE_ANALYTICS_ENABLED
);
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		{
			googleAnalyticsEnabled ? (
				<>
					<!-- Google tag (gtag.js) -->
					<script
						async
						src="https://www.googletagmanager.com/gtag/js?id=G-5DQXQ5WGZY"
					></script>
					<script is:inline>
						window.dataLayer = window.dataLayer || [];
						function gtag() {dataLayer.push(arguments);}
						gtag("js", new Date());
						gtag("config", "G-5DQXQ5WGZY");
					</script>
				</>
			) : null
		}
	</head>
	<body>
		<header class="header">
			<div class="container nav">
				<a class="brand" href="/">
					<img
						class="brand-wordmark"
						src="/brand/professional-logo-horizontal.png"
						alt={companyName}
						width="440"
						height="72"
						decoding="async"
					/>
				</a>
				<nav class="menu" aria-label="Primary navigation">
					{navItems.map(({ label, href }) => (
						<a
							href={href}
							class={isActive(href) ? "is-active" : undefined}
							aria-current={isActive(href) ? "page" : undefined}
						>
							{label}
						</a>
					))}
				</nav>
				<a
					href="/contact/"
					class:list={{
						"primary-button": true,
						"header-cta": true,
						"header-cta--hidden": isContactPage,
					}}
					aria-hidden={isContactPage ? "true" : undefined}
					tabindex={isContactPage ? "-1" : undefined}
				>
					Book a Call
				</a>
				<details class="mobile-menu">
					<summary class="mobile-menu__toggle" aria-label="Open menu">
						<span class="mobile-menu__icon" aria-hidden="true">
							<span class="mobile-menu__bar"></span>
							<span class="mobile-menu__bar"></span>
							<span class="mobile-menu__bar"></span>
						</span>
						<span class="visually-hidden">Menu</span>
					</summary>
					<div class="mobile-menu__panel" aria-label="Mobile navigation">
						<nav class="mobile-menu__links" aria-label="Primary navigation (mobile)">
							{navItems.map(({ label, href }) => (
								<a
									href={href}
									class={isActive(href) ? "is-active" : undefined}
									aria-current={isActive(href) ? "page" : undefined}
								>
									{label}
								</a>
							))}
						</nav>
						<a
							href="/contact/"
							class:list={{
								"primary-button": true,
								"mobile-menu__cta": true,
								"header-cta--hidden": isContactPage,
							}}
							aria-hidden={isContactPage ? "true" : undefined}
							tabindex={isContactPage ? "-1" : undefined}
						>
							Book a Call
						</a>
					</div>
				</details>
			</div>
		</header>

		<slot />

		<SiteFooter companyName={companyName} />

		<script is:inline>
			const revealElements = document.querySelectorAll(".reveal");
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add("reveal-visible");
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.2 }
			);

			revealElements.forEach((element) => observer.observe(element));
		</script>
		<script is:inline>
			const mobileMenu = document.querySelector("details.mobile-menu");
			if (mobileMenu) {
				mobileMenu.addEventListener("click", (event) => {
					const target = event.target;
					if (!(target instanceof Element)) return;
					const isNavLink = target.closest("a");
					if (isNavLink) mobileMenu.removeAttribute("open");
				});

				document.addEventListener("click", (event) => {
					if (!mobileMenu.hasAttribute("open")) return;
					const target = event.target;
					if (!(target instanceof Element)) return;
					if (mobileMenu.contains(target)) return;
					mobileMenu.removeAttribute("open");
				});

				document.addEventListener("keydown", (event) => {
					if (event.key !== "Escape") return;
					if (!mobileMenu.hasAttribute("open")) return;
					mobileMenu.removeAttribute("open");
				});
			}
		</script>
	</body>
</html>
